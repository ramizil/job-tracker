# ---------------------------------------------------------------------------
# Job-search aggregator API keys (all optional - the tracker works without them;
# you only need a key for the `jobtracker search` command).
# Copy this file to ".env" and fill in the keys you have.
# ---------------------------------------------------------------------------

# JSearch (RapidAPI) - PRIMARY for Israel. Aggregates Google-for-Jobs results,
# which include LinkedIn / Indeed / Glassdoor postings.
# 1) Sign up: https://rapidapi.com/  2) Subscribe (free tier) to "JSearch"
# 3) Copy your X-RapidAPI-Key here.
RAPIDAPI_KEY=

# Jooble - free job-search API with Israel coverage.
# Request a free key: https://jooble.org/api/about
JOOBLE_API_KEY=

# Adzuna - optional (NO Israel coverage; useful for remote / UK / US / EU).
# https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# AI provider for all AI features: gemini | openai | anthropic | cursor
AI_PROVIDER=gemini

# Gemini AI (resume fit analysis + tailoring). Get a key at
# https://aistudio.google.com/app/apikey (keys usually start with "AIza...").
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Cursor (via a LOCAL OpenAI-compatible proxy). Cursor has no native
# chat/completions API, so you must run a proxy that wraps the Cursor Agent CLI
# and re-exposes an OpenAI-shaped endpoint, e.g.:
#   https://github.com/Randomblock1/cursor-openai-api
#   https://github.com/tageecc/cursor-agent-api-proxy
# Get an API key at https://cursor.com/dashboard/integrations, start the proxy,
# then set the values below (CURSOR_BASE_URL = the proxy's /v1 URL).
CURSOR_API_KEY=
CURSOR_MODEL=auto
CURSOR_BASE_URL=http://localhost:8080/v1

# Path to your resume (HTML). Used to build the matching profile.
# Defaults to the bundled sample if unset.
RESUME_PATH=

# Google Sheets sync (optional). Paste the Drive folder URL where the
# "Job Tracker Applications" sheet should live; the app creates and updates it.
# One-time setup: create a Desktop-app OAuth client in Google Cloud Console
# (enable the Drive + Sheets APIs), download its JSON, and put it at the path
# below (default: data/google_client_secret.json). Then click "Connect Google"
# on the Settings page.
GDRIVE_FOLDER=
GOOGLE_CLIENT_SECRET=
